	<script>
		(function() {
			const isUserLoggedIn = document.cookie.includes('isUserLoggedIn');
			const currentUrl = window.location.href;
			const baseUrl = 'https://www.emovid.com';
    		const inboxUrl = 'https://app.emovid.com/dashboard/inbox';

			const isExactHomePage = currentUrl === baseUrl || currentUrl === baseUrl + '/';
			if (isUserLoggedIn && isExactHomePage) {
				window.location.href = inboxUrl;
				return;
			}
		})();
	</script>
	<link rel="preload" as="image" href="https://test.emovid.com/wp-content/uploads/2025/04/col-17-768x843.webp" imagesrcset="https://test.emovid.com/wp-content/uploads/2025/04/col-17.webp 1385w, https://test.emovid.com/wp-content/uploads/2025/04/col-17-768x843.webp 768w" imagesizes="(max-width: 1385px) 100vw, 1385px" fetchpriority="high">
    <script>
    document.addEventListener('DOMContentLoaded', function() {
        const creditText = document.querySelectorAll('.credit-text');
        const getStartedFreeBtnDiv = document.querySelectorAll('.get-started-free-cta-btn');
        function getCookie(name) {
            const value = `; ${document.cookie}`;
            const parts = value.split(`; ${name}=`);
            if (parts.length === 2) return parts.pop().split(';').shift();
        }
        const planParam = getCookie('userPlan');
        const upgradefromParam = getCookie('upgradefrom');
        switch(planParam) {
            case 'personal':
                getStartedFreeBtnDiv.forEach(div => {
                    const getStartedFreeBtn = div.querySelector('a');
                    if (getStartedFreeBtn) {
                        getStartedFreeBtn.textContent = 'Upgrade';
                        getStartedFreeBtn.href = 'https://www.emovid.com/pricing';
                    }
                });
                break;
            case 'professional':
                getStartedFreeBtnDiv.forEach(div => {
                    const getStartedFreeBtn = div.querySelector('a');
                    if (getStartedFreeBtn) {
                        getStartedFreeBtn.textContent = 'Upgrade';
                        if (upgradefromParam === "trial") {
                            getStartedFreeBtn.href = 'https://app.emovid.com/?plan=professional&duration=annually&type=upgrade';
                        } else if (upgradefromParam === "paid") {
                            getStartedFreeBtn.href = 'https://www.emovid.com/pricing';
                        } else {
                            getStartedFreeBtn.href = 'https://www.emovid.com/pricing';
                        }
                    }
                });
                break;
            case 'business':
                getStartedFreeBtnDiv.forEach(div => {
                    const getStartedFreeBtn = div.querySelector('a');
                    if (getStartedFreeBtn) {
                        getStartedFreeBtn.textContent = 'Upgrade';
                        if (upgradefromParam === "trial") {
                            getStartedFreeBtn.href = 'https://app.emovid.com/?plan=business&duration=annually&type=upgrade';
                        } else if (upgradefromParam === "paid") {
                            getStartedFreeBtn.href = 'https://www.emovid.com/pricing';
                        } else {
                            getStartedFreeBtn.href = 'https://www.emovid.com/pricing';
                        }
                    }
                });
                break;
            case 'enterprise':
                getStartedFreeBtnDiv.forEach(div => {
                    div.classList.add('hide-get-started-free-cta-btn');
                });
                break;
            default:
                break;
        }
        if (planParam){
            if (creditText && creditText.length > 0){
                creditText.forEach(text => {
                    text.classList.add('hide-get-started-free-cta-btn');
                });
            }
        }
    });
    </script>
