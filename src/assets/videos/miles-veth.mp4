<div  class="simple-banner simple-banner-text" style="display:none !important"></div><input type="hidden" id="csrf_token" name="csrf_token" value="069c2b432c">
    <script>
        const typingElement = document.getElementById('banner-animated-text');
        const cursorElement = document.getElementById('animated-cursor-text') || document.querySelector('.banner-cursor');
        const sentences = [
            { text: "Recorded, bi-directional, secure video/audio communication for business.", boldWords: ["Recorded"] },
            { text: "Fast, clear, human communication at scale.", boldWords: [] },
            { 
                base: "Works with your current business: ", 
                variants: ["email apps.", "office apps.", "crm apps.", "marketing apps."], 
                final: "LinkedIn, TXT, WhatsApp.",
                boldWords: []
            },
            { text: "No installs, downloads or recipient signups.", boldWords: [] }
        ];
        
        let currentSentenceIndex = 0;
        let currentCharIndex = 0;
        let currentVariantIndex = 0;
        let isDeleting = false;
        let isPartialDeleting = false;
        let typingSpeed = 80;
        let deletingSpeed = 20;
        let pauseAfterTyping = 1000;
        let pauseAfterDeleting = 500;
        let cursorShown = false;

        function getBoldRanges(text) {
            const currentSentence = sentences[currentSentenceIndex];
            let boldWords = [];
            
            if (typeof currentSentence === 'object' && currentSentence.text) {
                boldWords = currentSentence.boldWords || [];
            } else if (typeof currentSentence === 'object' && currentSentence.base) {
                boldWords = currentSentence.boldWords || [];
            }

            if (boldWords.length === 0) return [];

            const ranges = [];
            boldWords.forEach(word => {
                const regex = new RegExp(`\\b${word}\\b`, 'gi');
                let match;
                while ((match = regex.exec(text)) !== null) {
                    ranges.push({
                        start: match.index,
                        end: match.index + word.length,
                        word: word
                    });
                }
            });

            return ranges;
        }

        function applyBoldFormatting(text) {
            const fullText = getCurrentText();
            const boldRanges = getBoldRanges(fullText);
            
            if (boldRanges.length === 0) return text;

            let result = '';
            let lastIndex = 0;

            boldRanges.forEach(range => {
                // Only apply bold if we've typed past the start of the bold word
                if (text.length > range.start) {
                    // Add text before the bold word
                    result += text.substring(lastIndex, range.start);
                    
                    // Add the bold word (or the part of it that's been typed)
                    const boldEnd = Math.min(range.end, text.length);
                    const boldText = text.substring(range.start, boldEnd);
                    result += `<span class="bold-word">${boldText}</span>`;
                    
                    lastIndex = boldEnd;
                }
            });

            // Add remaining text
            result += text.substring(lastIndex);

            return result;
        }

        function getCurrentText() {
            const currentSentence = sentences[currentSentenceIndex];
            
            if (typeof currentSentence === 'object' && currentSentence.base) {
                if (currentVariantIndex === -1) {
                    return "Works with " + currentSentence.final;
                }
                const variant = currentSentence.variants[currentVariantIndex];

                const isMobile = window.innerWidth <= 768;
                const separator = isMobile ? '<br>' : '';

                return currentSentence.base + separator + variant;
            }
            return currentSentence.text;
        }

        function getBaseText() {
            const currentSentence = sentences[currentSentenceIndex];
            if (typeof currentSentence === 'object' && currentSentence.base) {
                if (currentVariantIndex === -1) {
                    return "Works with ";
                }
                if (currentVariantIndex === currentSentence.variants.length - 1 && isPartialDeleting) {
                    return "Works with ";
                }

                const isMobile = window.innerWidth <= 768;
                const separator = isMobile ? '<br>' : '';

                return currentSentence.base + separator;
            }
            return "";
        }

        function updateText(text) {
            typingElement.innerHTML = applyBoldFormatting(text);
        }

        function typeText() {
            // Show cursor 3ms before first character appears
            if (cursorElement && !cursorShown && currentCharIndex === 0 && !isDeleting && !isPartialDeleting) {
                cursorShown = true;
                setTimeout(() => {
                    if (cursorElement) {
                        cursorElement.style.display = 'inline-block';
                    }
                }, Math.max(0, typingSpeed - 3));
            }
            
            const currentText = getCurrentText();
            const currentSentence = sentences[currentSentenceIndex];
            
            if (!isDeleting && !isPartialDeleting && currentCharIndex < currentText.length) {
                if (currentText.substring(currentCharIndex, currentCharIndex + 4) === '<br>') {
                    // Skip the entire <br> tag at once
                    currentCharIndex += 4;
                    updateText(currentText.substring(0, currentCharIndex));
                    setTimeout(typeText, 0); // Continue immediately
                } else {
                    updateText(currentText.substring(0, currentCharIndex + 1));
                    currentCharIndex++;
                    setTimeout(typeText, typingSpeed);
                }
            } else if (!isDeleting && !isPartialDeleting && currentCharIndex === currentText.length) {
                setTimeout(() => {
                    if (typeof currentSentence === 'object' && currentSentence.base) {
                        if (currentVariantIndex === -1) {
                            isDeleting = true;
                        } else if (currentVariantIndex < currentSentence.variants.length - 1) {
                            isPartialDeleting = true;
                        } else {
                            isPartialDeleting = true;
                        }
                    } else {
                        isDeleting = true;
                    }
                    typeText();
                }, pauseAfterTyping);
            } else if (isPartialDeleting && typeof currentSentence === 'object' && currentSentence.base) {
                const baseText = getBaseText();
                if (currentCharIndex > baseText.length) {
                    const textBeforeCursor = currentText.substring(0, currentCharIndex);
                    if (textBeforeCursor.endsWith('<br>')) {
                        // Delete the entire <br> tag at once
                        currentCharIndex -= 4;
                        updateText(currentText.substring(0, currentCharIndex));
                        setTimeout(typeText, 0); // Continue immediately
                    } else {
                        updateText(currentText.substring(0, currentCharIndex - 1));
                        currentCharIndex--;
                        setTimeout(typeText, deletingSpeed);
                    }
                } else {
                    isPartialDeleting = false;
                    if (currentVariantIndex === currentSentence.variants.length - 1) {
                        currentVariantIndex = -1;
                    } else {
                        currentVariantIndex = (currentVariantIndex + 1) % currentSentence.variants.length;
                    }
                    setTimeout(typeText, pauseAfterDeleting);
                }
            } else if (isDeleting && currentCharIndex > 0) {
                updateText(currentText.substring(0, currentCharIndex - 1));
                currentCharIndex--;
                setTimeout(typeText, deletingSpeed);
            } else if (isDeleting && currentCharIndex === 0) {
                isDeleting = false;
                isPartialDeleting = false;
                currentSentenceIndex = (currentSentenceIndex + 1) % sentences.length;
                currentVariantIndex = 0;
                setTimeout(typeText, pauseAfterDeleting);
            }
        }

        window.addEventListener('DOMContentLoaded', () => {
            typeText();
        });
    </script>
    <script type="module" src="https://www.emovid.com/wp-includes/js/dist/script-modules/block-library/navigation/view.min.js?ver=b0f909c3ec791c383210" id="@wordpress/block-library/navigation/view-js-module" fetchpriority="low" data-wp-router-options="{&quot;loadOnClientNavigation&quot;:true}"></script>
<script id="wp-block-template-skip-link-js-after">
	( function() {
		var skipLinkTarget = document.querySelector( 'main' ),
			sibling,
			skipLinkTargetID,
			skipLink;

		// Early exit if a skip-link target can't be located.
		if ( ! skipLinkTarget ) {
			return;
		}

		/*
		 * Get the site wrapper.
		 * The skip-link will be injected in the beginning of it.
		 */
		sibling = document.querySelector( '.wp-site-blocks' );

		// Early exit if the root element was not found.
		if ( ! sibling ) {
			return;
		}

		// Get the skip-link target's ID, and generate one if it doesn't exist.
		skipLinkTargetID = skipLinkTarget.id;
		if ( ! skipLinkTargetID ) {
			skipLinkTargetID = 'wp--skip-link--target';
			skipLinkTarget.id = skipLinkTargetID;
		}

		// Create the skip link.
		skipLink = document.createElement( 'a' );
		skipLink.classList.add( 'skip-link', 'screen-reader-text' );
		skipLink.id = 'wp-skip-link';
		skipLink.href = '#' + skipLinkTargetID;
		skipLink.innerText = 'Skip to content';

		// Inject the skip link.
		sibling.parentElement.insertBefore( skipLink, sibling );
	}() );
	
//# sourceURL=wp-block-template-skip-link-js-after
</script>
